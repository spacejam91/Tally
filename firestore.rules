rules_version = '2';

// ─────────────────────────────────────────────────────────────
// Tally — Firestore security rules
// Paste these into: Firestore Database → Rules → Publish
//
// Model: a "household" is one shared space for the two of you,
// keyed by the household code you both type in. Any signed-in
// (anonymous) user who knows the code can read/write that
// household. So: keep your household code long and private.
// ─────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // Everything under a household requires you to be signed in.
    match /households/{householdCode} {
      allow read, write: if request.auth != null;

      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
