rules_version = '2';

// ─────────────────────────────────────────────────────────────
// Tally — Firestore security rules (v2, hardened)
// Paste into: Firestore Database → Rules → Publish
//
// Model: a "household" is one shared space keyed by the private
// household code. Security properties:
//   • `get` (single doc by exact path) is allowed for signed-in
//     users — you must already KNOW the code.
//   • `list` on the households collection is DENIED — nobody can
//     enumerate household codes to discover data.
//   • Subcollections are only reachable through a path that
//     contains the code, and no {path=**} rule exists, so
//     collection-group queries across households are denied.
// Keep your household code long and private — it is the key.
// ─────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    match /households/{householdCode} {
      // exact-path access only; the collection cannot be listed
      allow get, create, update, delete: if request.auth != null;
      allow list: if false;

      match /transactions/{docId} {
        allow read, write: if request.auth != null;
      }
      match /recurring/{docId} {
        allow read, write: if request.auth != null;
      }
      match /receipts/{docId} {
        allow read, write: if request.auth != null;
      }
      match /trash/{docId} {
        allow read, write: if request.auth != null;
      }
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
